# PasteKing Environment Variables
# Copy to .env and fill in values

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pasteking:pasteking@localhost:5432/pasteking

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO / S3 ──────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=pasteking
S3_SECRET_KEY=pasteking123
S3_BUCKET=pasteking
S3_REGION=us-east-1

# ─── Session / Auth ──────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-string-at-least-32-characters
SESSION_MAX_AGE_HOURS=72

# ─── Storage ─────────────────────────────────────────────────────────────────
# Content ≤ this size (bytes) is stored inline in PostgreSQL; larger in S3
STORAGE_THRESHOLD=65536

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000

# ─── Web ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5

# ─── OAuth (optional) ────────────────────────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Stripe Billing (optional) ───────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_PRICE_ID=
# STRIPE_TEAM_PRICE_ID=
